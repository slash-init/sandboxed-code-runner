# Server Configuration
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Docker Execution Limits
MAX_EXECUTIONS=5
TIME_LIMIT=2000 # 2 seconds max execution time per run

# Database Configuration (PostgreSQL + Prisma)
# Replace these with your actual Supabase / Neon connection strings
# For Supabase, use the connection pooler URL (port 6543) here:
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# And use the direct connection URL (port 5432) here for Prisma migrations:
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"
